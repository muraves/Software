configfile: 'config.yaml'
configfile: '../../tag/requirements.yaml'
import os
import multiprocessing
from muraves_lib import snakefile_helper
# IMPROVEMENTS:
# The number of boards and channel should go in another configuration file

#>>>>>~~~~~~~~~~~~~~~~~~ GLOBAL PARAMETERS  ~~~~~~~~~~~~~~~~~~~
PNFS = config['data_path']
HOME = os.path.expandvars('/user/abiolchi/muraves_outputs')
BATCH_SIZE = config['batch_size'] 
THREADS = config['threads']
if config['run']:
    runs = snakefile_helper.parse_runs(config['run'])  # convert config file format into list of runs.
    BATCHES = list(snakefile_helper.batch_runs(runs, BATCH_SIZE))  # # create batches: [[2500,2501,2502], [2503,2504,2505], ...]
    BATCH_IDX = range(len(BATCHES))
else:
    BATCH_IDX = snakefile_helper.parse_batch_indices(config['batch_idx'])
overwrite_outputs=config['overwrite_outputs'],
log_on_console=config['logs_on_console'],
verbose=config['verbose'],
#<<<<<~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~

localrules: all

rule all:
    input:
        expand(
            '{output_path}/PEDESTAL/{color}/{version}/PIEDISTALLI_batch{batch_idx}.stamp',
            output_path=PNFS if config.get('copy_to_data') else HOME,
            color=config['hodoscope'],
            version=config['version'],
            #type=config['type'], 
            ## NB: this isn't needed anymore if rule all want's to produce output of pedestal rule or analysis rule, as in this case the dependance is explicit.
            batch_idx=BATCH_IDX
        )


rule parse_batch:
    threads: THREADS
    container: '/user/abiolchi/muraves-sing.sif'
    input:
        script="1_Parser/prep.py"
    params:
        raw_data_path=f'{PNFS}/RAW_GZ/{{color}}',
        runs=lambda wildcards:
            ( BATCHES[int(wildcards.batch_idx)] if config.get('run')
                else list(range(int(batch_idx) * BATCH_SIZE, int(wildcards.batch_idx) * BATCH_SIZE + BATCH_SIZE))
            ),  
    output:
        output_filename="{output_path}/PARSED/{color}/{version}/{type}_batch{batch_idx}.stamp" #Questo output contiene la lista dei file prodotti dal batch, che saranno usati come input per le regole successive.
    shell:
        "python {input.script} -i {params.raw_data_path} -th {threads} -t {wildcards.type} -r {params.runs} -o {output.output_filename} -l {log_on_console} -v {verbose} -ow {overwrite_outputs}"

rule prereco:
    threads: THREADS
    container: '/user/abiolchi/muraves-sing.sif'
    input:
        script = '2_PreRec/MakePedestalTree.py',
        input_filename = "{output_path}/PARSED/{color}/{version}/{type}_batch{batch_idx}.stamp"
    params:
        nBoards = 16,
        nInfoBoard = 39,
        nChannels= 32
    output:
        output_filename = "{output_path}/PRERECONSTRUCTED/{color}/{version}/{type}_batch{batch_idx}.stamp"
    shell: "python {input.script} -i {input.input_filename} -info {params.nBoards} {params.nInfoBoard} {params.nChannels} -o {output.output_filename} -th {threads} -l {log_on_console} -v {verbose} -ow {overwrite_outputs}"



rule pedestal_analysis:
    threads: THREADS
    container: '/user/abiolchi/muraves-sing.sif'
