    params: # to be removed at next version
        nBoards = 16,
        nInfoBoard = 39,
        nChannels= 32,
        overwrite_outputs = "True"

    #    number_of_runs = 1
    #    delta_around_central_runID = 0
    output:
        output_filename = "{output_path}/PEDESTAL/{color}/{version}/PIEDISTALLI_batch{batch_idx}.stamp",
        #sub_files = 
        #expand(
        #    "{{output_path}}/PEDESTAL/{{color}}/{{version}}/{run}/pedestal_{n}.cfg", run = lambda wildcards:
        #    ( BATCHES[int(wildcards.batch_idx)] if config.get('run')
        #        else list(range(int(batch_idx) * BATCH_SIZE, int(wildcards.batch_idx) * BATCH_SIZE + BATCH_SIZE))
        #    ),   n = range(16)
        #) ##NB: CONS--> these subruns will remain silents, the success has to be checks through logs 
    shell: "python {input.script} -i {input.input_filename} -info {params.nBoards} {params.nInfoBoard} {params.nChannels} -o {output.output_filename} -th {threads} -l {log_on_console} -v {verbose} -ow {params.overwrite_outputs}"



